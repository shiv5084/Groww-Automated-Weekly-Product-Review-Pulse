# =============================================================================
# Groww Automated Weekly Product Review Pulse — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
*.pyo

# Virtual environments
venv/
.venv/
env/
.env_dir/
ENV/

# -----------------------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
*.env
credentials.json
token.json
token.pickle
client_secret*.json
service_account*.json
credentials/
!credentials/.gitkeep

# -----------------------------------------------------------------------------
# Scraped / Raw Data — auto-generated, not committed
# -----------------------------------------------------------------------------
data/raw/
!data/raw/.gitkeep
data/cleaned/
!data/cleaned/.gitkeep

# Keep sample data committed
!data/sample/

# -----------------------------------------------------------------------------
# Output files — generated at runtime
# -----------------------------------------------------------------------------
output/notes/*.md
output/logs/*.log
output/logs/*.txt
!output/notes/.gitkeep
!output/logs/.gitkeep

# -----------------------------------------------------------------------------
# IDE & OS
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Playwright
# -----------------------------------------------------------------------------
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Jupyter (if used for exploration)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak

#custom files
prompt.md
issue.md
rule.md
