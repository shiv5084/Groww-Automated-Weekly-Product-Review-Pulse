{
  "_comment": "Deployed CustomGoogle MCP server (Railway). OAuth lives on the server — see shiv5084/MCP-SERVER.",
  "mcpServers": {
    "groww-pulse": {
      "url": "${MCP_SERVER_URL}",
      "description": "https://mcp-server-production-5084.up.railway.app"
    }
  },
  "endpoints": {
    "health": "GET /",
    "list_tools": "GET /tools",
