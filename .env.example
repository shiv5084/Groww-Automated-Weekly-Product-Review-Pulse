# =============================================================================
# Groww Automated Weekly Product Review Pulse — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (choose one)
# -----------------------------------------------------------------------------

# Option A: Groq (recommended — fast inference, generous free tier)
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Option B: OpenAI (uncomment to use instead)
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Phase 4 — Deployed MCP server (Google Docs + Gmail)
# Server: https://github.com/shiv5084/MCP-SERVER (OAuth configured on Railway)
# -----------------------------------------------------------------------------
MCP_SERVER_URL=https://mcp-server-production-5084.up.railway.app

# Pre-created master Google Doc for append-only weekly pulses (from doc URL:
# https://docs.google.com/document/d/<THIS_ID>/edit)
GOOGLE_MASTER_DOC_ID=your_master_google_doc_id_here

# -----------------------------------------------------------------------------
# Pipeline Configuration
# -----------------------------------------------------------------------------

# Number of weeks of reviews to include (default: 12)
REVIEW_WEEKS=12

# Maximum reviews to scrape per store (default: 500)
MAX_REVIEWS_PER_STORE=500

# Gmail draft recipient (the team distribution list or individual)
PULSE_EMAIL_RECIPIENT=your-team@example.com

# Gmail draft subject prefix
PULSE_EMAIL_SUBJECT_PREFIX=Groww Weekly Pulse

# -----------------------------------------------------------------------------
# Paths (relative to project root — change only if needed)
# -----------------------------------------------------------------------------
RAW_DATA_DIR=data/raw
CLEANED_DATA_DIR=data/cleaned
OUTPUT_NOTES_DIR=output/notes
OUTPUT_LOGS_DIR=output/logs

# -----------------------------------------------------------------------------
# Optional: Playwright / Scraper Settings
# -----------------------------------------------------------------------------

# Headless mode for Playwright (true = no browser window, recommended for CI)
PLAYWRIGHT_HEADLESS=true

# Minimum and maximum delay between scroll actions (seconds)
SCRAPER_DELAY_MIN=1
SCRAPER_DELAY_MAX=3
